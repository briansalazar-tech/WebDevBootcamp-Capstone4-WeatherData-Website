<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Carter+One&family=Oleo+Script:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link href="styles/styles.css" rel="stylesheet" />
    <title>Weather Data</title>
  </head>
  <body>
    <section id="header-section">
      <div class="container">
        <h1>
          Weather Outlook <span class="red-text">@ </span
          ><span id="script-text">Blue Heaven On Earth</span> ⚾
        </h1>
        <h2>🌍 118.240784 34.073814</h2>
      </div>
    </section>
    <section id="body-section">
      <div class="container">
        <div class="row">
          <div class="col-12" id="list-section">
            <p>Outlook for the next five days....</p>            
            <% for (let i = 0; i < content.temps.length; i++) { %>
            <ul>
              <li>On <span class="red-text"><%- content.dateTimes[i] %></span>, it will be <span class="red-text"><%- content.temps[i] %></span> degrees. Expect <span class="red-text"><%- content.descriptions[i] %></span></li>
            </ul>
            <% } %>
            <p><a href="https://www.google.com/maps/place/Dodger+Stadium/@34.073851,-118.2425332,1259m/data=!3m2!1e3!4b1!4m6!3m5!1s0x80c2c6f954005675:0x9e94554f839c09df!8m2!3d34.073851!4d-118.2399583!16zL20vMHB6cGs?entry=ttu&g_ep=EgoyMDI2MDMyMy4xIKXMDSoASAFQAw%3D%3D">Directions</a></p>
          </div>
        </div>
      </div>
    </section>
  </body>
</html>
